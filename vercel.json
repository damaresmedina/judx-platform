{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/backup",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron-sync-stj-datasets",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/sync-stf-decisoes",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/sync-stf-partes",
      "schedule": "0 8 * * 0"
    },
    {
      "path": "/api/normalize-judx?mode=core&source=stf_decisoes&limit=1500",
      "schedule": "*/4 * * * *"
    }
  ]
}
